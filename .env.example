# resend-client Environment Variables

## Worker Secrets (set via `wrangler secret put`)
# Never put real values here — this file is safe to commit

## Required — Encryption & Auth
MASTER_ENCRYPTION_KEY=   # 64-char random hex string (openssl rand -hex 32)
JWT_SECRET=              # 64-char random string for signing JWTs
ADMIN_USERNAME=          # Your admin login username
ADMIN_PASSWORD_HASH=     # bcrypt hash of your password (generate via setup script)

## Optional — set in wrangler.jsonc [vars] section (not secrets)
ENVIRONMENT=production
