{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config ../wrangler.jsonc",
    "deploy": "wrangler deploy --env=\"\" --config ../wrangler.jsonc",
    "types": "wrangler types --config ../wrangler.jsonc worker-configuration.d.ts",
    "db:apply": "wrangler d1 execute resend-client-db --local --file=./schema.sql --config ../wrangler.jsonc",
    "db:apply:remote": "wrangler d1 execute resend-client-db --remote --file=./schema.sql --config ../wrangler.jsonc"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.0",
    "nanoid": "^5.1.0",
    "resend": "^6.12.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^6.0.0",
    "wrangler": "^4.101.0"
  }
}
